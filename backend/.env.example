# Copy to .env and fill in values

# Optional — leave empty to run in DEMO mode (heuristic agents, no OpenAI calls)
OPENAI_API_KEY=

# Model overrides
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Database — default SQLite; for Postgres/Supabase use:
# DATABASE_URL=postgresql://user:password@host:5432/career_intelligence
DATABASE_URL=sqlite:///./career_intelligence.db

# Force demo heuristics even if API key is set
DEMO_MODE=false

CORS_ORIGINS=http://localhost:5173,http://localhost:3000
DEBUG=true
